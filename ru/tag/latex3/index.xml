&lt;details class="print:hidden xl:hidden" &gt;
&lt;summary&gt;Содержание&lt;/summary&gt;
&lt;div class="text-sm"&gt;
&lt;nav id="TableOfContents"&gt;
&lt;ul&gt;
&lt;li&gt;&lt;a href="#интерфейс-keys-define-nn"&gt;&lt;span class="section-num"&gt;1&lt;/span&gt; Интерфейс &lt;code&gt;\keys_define:nn&lt;/code&gt;&lt;/a&gt;
&lt;ul&gt;
&lt;li&gt;&lt;a href="#общая-информация"&gt;&lt;span class="section-num"&gt;1.1&lt;/span&gt; Общая информация&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href="#детальное-описание-работы"&gt;&lt;span class="section-num"&gt;1.2&lt;/span&gt; Детальное описание работы&lt;/a&gt;
&lt;ul&gt;
&lt;li&gt;&lt;a href="#определение-типов-ключей"&gt;&lt;span class="section-num"&gt;1.2.1&lt;/span&gt; Определение типов ключей&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href="#установка-начальных-значений"&gt;&lt;span class="section-num"&gt;1.2.2&lt;/span&gt; Установка начальных значений&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href="#обработчики-ключей"&gt;&lt;span class="section-num"&gt;1.2.3&lt;/span&gt; Обработчики ключей&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href="#проверка-корректности-значений"&gt;&lt;span class="section-num"&gt;1.2.4&lt;/span&gt; Проверка корректности значений&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href="#пример-полного-определения-ключей"&gt;&lt;span class="section-num"&gt;1.2.5&lt;/span&gt; Пример полного определения ключей:&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href="#использование-определённых-ключей-в-документе"&gt;&lt;span class="section-num"&gt;1.2.6&lt;/span&gt; Использование определённых ключей в документе&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;/li&gt;
&lt;/ul&gt;
&lt;/li&gt;
&lt;/ul&gt;
&lt;/nav&gt;
&lt;/div&gt;
